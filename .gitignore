# Build artifacts
bin/
obj/
*.user

# IDE
.vs/
.idea/
*.sln.iml

# Plugin's compile-time references
# - Assembly-CSharp.dll: publicized STUB of the game's assembly (method
#   signatures only, no IL bodies). Committed so CI can build. Regenerate
#   after game updates via:
#     assembly-publicizer <game>/Assembly-CSharp.dll -o VGEcho/lib/Assembly-CSharp.dll
VGEcho/lib/*.dll
VGEcho/lib/*.pdb
!VGEcho/lib/Assembly-CSharp.dll

# Local overrides
*.local

# Claude Code runtime state
.claude/

# Release staging artifacts produced by the release workflow
dist/
